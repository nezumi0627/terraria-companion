{
  "name": "terraria-web-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "sprites:download": "node scripts/download-sprites.mjs",
    "sprites:retry": "node scripts/download-sprites.mjs --retry-failed",
    "data:fetch-wiki": "node scripts/fetch-wiki-data.mjs",
    "data:generate-catalog": "node scripts/generate-catalog.mjs",
    "data:fetch-missing": "node scripts/fetch-missing-items.mjs",
    "data:fix-names": "node scripts/fix-wiki-names.mjs",
    "data:clean-desc": "node scripts/clean-wiki-descriptions.mjs",
    "data:clean-public": "node scripts/clean-public-descriptions.mjs",
    "data:deep-clean": "node scripts/deep-clean-descriptions.mjs",
    "data:refetch-desc": "node scripts/refetch-bad-descriptions.mjs",
    "data:fix-desc": "node scripts/fix-all-descriptions.mjs --refetch",
    "data:rebuild": "node scripts/rebuild-entity-text.mjs",
    "data:rebuild-bad": "node scripts/rebuild-entity-text.mjs --bad-only",
    "data:enrich": "node scripts/enrich-remaining.mjs",
    "data:merge-wiki": "node scripts/merge-wiki-into-app.mjs",
    "data:sync": "node scripts/fetch-wiki-data.mjs && node scripts/fix-wiki-names.mjs && node scripts/clean-wiki-descriptions.mjs && node scripts/generate-catalog.mjs && node scripts/merge-wiki-into-app.mjs && node scripts/download-sprites.mjs --retry-failed",
    "data:refresh-text": "node scripts/rebuild-entity-text.mjs --bad-only && node scripts/merge-wiki-into-app.mjs && node scripts/clean-public-descriptions.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@vercel/analytics": "1.6.1",
    "class-variance-authority": "^0.7.1",
